{
  "version": 2,
  "builds": [
    {
      "src": "api/analyze-devis.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/analyze-devis",
      "destination": "/api/analyze-devis.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
