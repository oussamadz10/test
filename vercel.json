{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/analyze-devis.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/api/analyze-devis",
      "dest": "/api/analyze-devis.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
